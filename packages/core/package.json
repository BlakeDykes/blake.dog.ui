{
  "name": "@blakedykes/core",
  "version": "0.1.0",
  "description": "Headless game-UI core: the token contract, structural + invariants layers, and behavior-only components that identity packages skin.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core.css": "./dist/core.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "tokens:build": "node build/tokens.mjs",
    "typecheck": "tsc --noEmit",
    "build": "pnpm tokens:build && tsc --noEmit && vite build",
    "lint:style": "stylelint \"src/**/*.scss\" --allow-empty-input"
  },
  "peerDependencies": {
    "@base-ui/react": "^1.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
