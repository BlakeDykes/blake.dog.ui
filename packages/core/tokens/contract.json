{
  "_comment": "The universal contract — the stable, identity-agnostic token names every identity package MUST populate under [data-identity] and every component skin reads. NOT emitted to CSS by core (values here are placeholders); this file is the manifest the shared token build asserts identities against. Capability tokens an identity lacks (glow, scanline) are NOT here — they live as identity-specific primitives in their own packages.",
  "color": {
    "$type": "color",
    "accent": {
      "primary": { "$value": "#000000" },
      "primary-hover": { "$value": "#000000" },
      "primary-active": { "$value": "#000000" },
      "secondary": { "$value": "#000000" }
    },
    "surface": {
      "scene": { "$value": "#000000" },
      "panel": { "$value": "#000000" },
      "raised": { "$value": "#000000" },
      "inset": { "$value": "#000000" }
    },
    "text": {
      "primary": { "$value": "#000000" },
      "accent": { "$value": "#000000" },
      "display": { "$value": "#000000" },
      "shadow": { "$value": "#000000" }
    },
    "border": {
      "primary": { "$value": "#000000" },
      "focus": { "$value": "#000000" }
    }
  },
  "text": {
    "size": {
      "$type": "dimension",
      "small": { "$value": "12px" },
      "medium": { "$value": "16px" },
      "large": { "$value": "24px" }
    },
    "shadow": {
      "offset": {
        "x": { "$value": "1px" },
        "y": { "$value": "1px" }
      },
      "blur": { "$value": "0px" }
    }
  },
  "border": {
    "width": {
      "$type": "dimension",
      "top": { "$value": "0px" },
      "right": { "$value": "0px" },
      "bottom": { "$value": "0px" },
      "left": { "$value": "0px" }
    }
  },
  "font": {
    "family": {
      "display": { "$value": "sans-serif" },
      "accent": { "$value": "sans-serif" }
    }
  },
  "space": {
    "$type": "dimension",
    "1": { "$value": "4px" },
    "2": { "$value": "8px" },
    "3": { "$value": "12px" },
    "4": { "$value": "16px" },
    "5": { "$value": "24px" },
    "6": { "$value": "32px" }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": "2px" },
    "md": { "$value": "4px" }
  }
}
