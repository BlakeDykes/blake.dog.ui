    "$type": "color",
    "primary": { "$value": "#000000" },
    "primary-hover": { "$value": "#000000" },
    "primary-active": { "$value": "#000000" },
    "secondary": { "$value": "#000000" }
  },
  "surface": {
    "$type": "color",
    "scene": { "$value": "#000000" },
    "panel": { "$value": "#000000" },
    "raised": { "$value": "#000000" }
  },
  "text": {
    "$type": "color",
    "primary": { "$value": "#000000" },
    "on-accent": { "$value": "#000000" },
    "display": { "$value": "#000000" }
  },
  "border": {
    "$type": "color",
    "frame": { "$value": "#000000" },
    "focus": { "$value": "#000000" }
  },
  "font": {
    "family": {
      "body": { "$value": "sans-serif" },
      "display": { "$value": "sans-serif" }
    }
  },
  "space": {
