{
  "color": {
    "$type": "color",
    "accent": {
      "primary": { "$value": "{pal.red.bright}" },
      "primary-hover": { "$value": "{pal.orange.bright}" },
      "primary-active": { "$value": "{pal.red.dark}" },
      "secondary": { "$value": "{pal.blue.bright}" }
    },
    "surface": {
      "scene": { "$value": "{pal.black}" },
      "panel": { "$value": "{pal.blue.dark}" },
      "raised": { "$value": "{pal.blue.bright}" },
      "inset": { "$value": "{pal.blue.darkest}" }
    },
    "text": {
      "primary": { "$value": "{pal.white}" },
      "display": { "$value": "{pal.white}" },
      "accent": { "$value": "{pal.olive.bright}" },
      "shadow": { "$value": "{pal.black}" }
    },
    "border": {
      "primary": { "$value": "{pal.white}" },
      "focus": { "$value": "{pal.olive.bright}" }
    }
  },
  "text": {
    "size": {
      "small": { "$value": "12px" },
      "medium": { "$value": "16px" },
      "large": { "$value": "24px" }
    },
    "shadow": {
      "offset": {
        "x": { "$value": "2px" },
        "y": { "$value": "2px" }
      },
      "blur": { "$value": "0px" }
    }
  },
  "border": {
    "width": {
      "top": { "$value": "3px" },
      "right": { "$value": "3px" },
      "bottom": { "$value": "3px" },
      "left": { "$value": "3px" }
    }
  },
  "font": {
    "family": {
      "display": {
        "$value": "\"Press Start 2P\", \"Pixelify Sans\", monospace"
      },
      "accent": {
        "$value": "\"Jacquard 12\", \"Press Start 2P\", \"Pixelify Sans\", monospace"
      }
    }
  },
  "space": {
    "$type": "dimension",
    "1": { "$value": "4px" },
    "2": { "$value": "8px" },
    "3": { "$value": "16px" },
    "4": { "$value": "24px" },
    "5": { "$value": "32px" },
    "6": { "$value": "48px" }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": "0px" },
    "md": { "$value": "0px" }
  }
}
