{
  "name": "@blakedykes/ui",
  "version": "0.3.0",
  "description": "Brand-neutral React design system: Base UI, DTCG tokens, SCSS modules.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/blakedykes/blake.dog.ds.git"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "tokens:build": "node build/style-dictionary.config.mjs",
    "typecheck": "tsc --noEmit",
    "build": "pnpm tokens:build && tsc --noEmit && vite build",
    "lint:style": "stylelint \"src/**/*.scss\"",
    "format": "prettier --write .",
    "storybook": "pnpm tokens:build && storybook dev -p 6006",
    "build-storybook": "pnpm tokens:build && storybook build",
    "prepare": "husky"
  },
  "peerDependencies": {
    "@base-ui/react": "^1.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@base-ui/react": "^1.5.0",
    "@storybook/addon-docs": "^9.1.20",
    "@storybook/react-vite": "^9.1.20",
    "@types/node": "^22.19.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "3.8.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sass-embedded": "^1.100.0",
    "storybook": "^9.1.20",
    "style-dictionary": "^4.4.0",
    "stylelint": "^17.13.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.5",
    "vite-plugin-dts": "^5.0.2",
    "vite-plugin-sass-dts": "^1.3.37"
  }
}
