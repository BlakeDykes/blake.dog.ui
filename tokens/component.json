{
  "button": {
    "bg": {
      "$type": "color",
      "solid": { "$value": "{color.accent}" },
      "solid-hover": { "$value": "{color.accent-hover}" },
      "solid-active": { "$value": "{color.accent-active}" },
      "ghost-hover": { "$value": "{color.bg-subtle}" },
      "danger": { "$value": "{color.danger}" },
      "danger-hover": { "$value": "{color.danger-hover}" }
    },
    "fg": {
      "$type": "color",
      "solid": { "$value": "{color.fg-on-accent}" },
      "ghost": { "$value": "{color.fg}" },
      "outline": { "$value": "{color.fg}" },
      "danger": { "$value": "{color.fg-on-accent}" }
    },
    "border": {
      "$type": "color",
      "outline": { "$value": "{color.border-strong}" }
    },
    "radius": { "$value": "{radius.md}", "$type": "dimension" },
    "gap": { "$value": "{space.xs}", "$type": "dimension" }
  },
  "input": {
    "bg": { "$value": "{color.bg-elevated}", "$type": "color" },
    "fg": { "$value": "{color.fg}", "$type": "color" },
    "placeholder": { "$value": "{color.fg-muted}", "$type": "color" },
    "border": { "$value": "{color.border}", "$type": "color" },
    "border-hover": { "$value": "{color.border-strong}", "$type": "color" },
    "border-focus": { "$value": "{color.accent}", "$type": "color" },
    "border-invalid": { "$value": "{color.danger}", "$type": "color" },
    "radius": { "$value": "{radius.md}", "$type": "dimension" },
    "padding-x": { "$value": "{space.sm}", "$type": "dimension" },
    "padding-y": { "$value": "{space.xs}", "$type": "dimension" }
  },
  "field": {
    "gap": { "$value": "{space.xs}", "$type": "dimension" },
    "label": {
      "fg": { "$value": "{color.fg}", "$type": "color" },
      "size": { "$value": "{font.size.sm}", "$type": "dimension" }
    },
    "description": {
      "fg": { "$value": "{color.fg-muted}", "$type": "color" },
      "size": { "$value": "{font.size.xs}", "$type": "dimension" }
    },
    "error": {
      "fg": { "$value": "{color.danger}", "$type": "color" },
      "size": { "$value": "{font.size.xs}", "$type": "dimension" }
    }
  }
}
