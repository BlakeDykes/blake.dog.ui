{
  "color": {
    "$type": "color",
    "white": { "$value": "#ffffff" },
    "black": { "$value": "#000000" },
    "gray": {
      "50": { "$value": "#f9fafb" },
      "100": { "$value": "#f3f4f6" },
      "200": { "$value": "#e5e7eb" },
      "300": { "$value": "#d1d5db" },
      "400": { "$value": "#9ca3af" },
      "500": { "$value": "#6b7280" },
      "600": { "$value": "#4b5563" },
      "700": { "$value": "#374151" },
      "800": { "$value": "#1f2937" },
      "900": { "$value": "#111827" },
      "950": { "$value": "#030712" }
    },
    "blue": {
      "50": { "$value": "#eff6ff" },
      "100": { "$value": "#dbeafe" },
      "200": { "$value": "#bfdbfe" },
      "300": { "$value": "#93c5fd" },
      "400": { "$value": "#60a5fa" },
      "500": { "$value": "#3b82f6" },
      "600": { "$value": "#2563eb" },
      "700": { "$value": "#1d4ed8" },
      "800": { "$value": "#1e40af" },
      "900": { "$value": "#1e3a8a" },
      "950": { "$value": "#172554" }
    },
    "red": {
      "50": { "$value": "#fef2f2" },
      "100": { "$value": "#fee2e2" },
      "200": { "$value": "#fecaca" },
      "300": { "$value": "#fca5a5" },
      "400": { "$value": "#f87171" },
      "500": { "$value": "#ef4444" },
      "600": { "$value": "#dc2626" },
      "700": { "$value": "#b91c1c" },
      "800": { "$value": "#991b1b" },
      "900": { "$value": "#7f1d1d" },
      "950": { "$value": "#450a0a" }
    }
  },
  "space": {
    "$type": "dimension",
    "0": { "$value": "0rem" },
    "25": { "$value": "0.125rem" },
    "50": { "$value": "0.25rem" },
    "100": { "$value": "0.5rem" },
    "150": { "$value": "0.75rem" },
    "200": { "$value": "1rem" },
    "300": { "$value": "1.5rem" },
    "400": { "$value": "2rem" },
    "600": { "$value": "3rem" },
    "800": { "$value": "4rem" }
  },
  "font": {
    "family": {
      "$type": "fontFamily",
      "sans": {
        "$value": "system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif"
      },
      "mono": {
        "$value": "ui-monospace, 'Cascadia Code', Consolas, 'Liberation Mono', monospace"
      }
    },
    "size": {
      "$type": "dimension",
      "100": { "$value": "0.75rem" },
      "200": { "$value": "0.875rem" },
      "300": { "$value": "1rem" },
      "400": { "$value": "1.125rem" },
      "500": { "$value": "1.25rem" },
      "600": { "$value": "1.5rem" },
      "700": { "$value": "1.875rem" },
      "800": { "$value": "2.25rem" },
      "900": { "$value": "3rem" }
    },
    "weight": {
      "$type": "fontWeight",
      "400": { "$value": 400 },
      "500": { "$value": 500 },
      "700": { "$value": 700 }
    },
    "line-height": {
      "$type": "number",
      "100": { "$value": 1.25 },
      "200": { "$value": 1.5 },
      "300": { "$value": 1.75 }
    }
  },
  "radius": {
    "$type": "dimension",
    "100": { "$value": "0.25rem" },
    "200": { "$value": "0.375rem" },
    "300": { "$value": "0.5rem" },
    "900": { "$value": "9999px" }
  },
  "border-width": {
    "$type": "dimension",
    "100": { "$value": "1px" },
    "200": { "$value": "2px" }
  },
  "duration": {
    "$type": "duration",
    "100": { "$value": "120ms" },
    "200": { "$value": "200ms" },
    "300": { "$value": "320ms" }
  },
  "easing": {
    "standard": { "$value": "cubic-bezier(0.2, 0, 0, 1)" }
  }
}
